#!/usr/bin/env sh
msg=$(cat "$1")
pattern='^(feat|fix|docs|style|refactor|perf|test|chore|revert|ci)(\(.+\))?: .{1,100}$'

if ! echo "$msg" | grep -qE "$pattern"; then
  echo ""
  echo "husky: commit message does not follow conventional commits format"
  echo ""
  echo "  Expected: type(scope): subject"
  echo "  Types:    feat fix docs style refactor perf test chore revert ci"
  echo "  Example:  feat(user): add login endpoint"
  echo "  Example:  chore: init spring boot project"
  echo ""
  echo "  Your message: $msg"
  echo ""
  exit 1
fi
